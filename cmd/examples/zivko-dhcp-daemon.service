[Unit]
Description=Zivko DHCP Go Backend
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
Environment=ZIVKO_DHCP_CONFIG_PATH=/var/lib/zivko-dhcp/config.json
ExecStart=/usr/local/bin/zivko-dhcp --headless
Restart=on-failure
RestartSec=2
RuntimeDirectory=zivko-dhcp
RuntimeDirectoryMode=0755

[Install]
WantedBy=multi-user.target
